// ═══════════════════════════════════════════════

[Persistence:store_json] -> [Config:theme] ::mod(
  rule="definitional",
  confidence=1.0,
  description="'light' | 'dark'"
)

[Persistence:store_json] -> [Config:fontSize] ::mod(
  rule="definitional",
  confidence=1.0,
  description="12-28, default 16"
)

[Persistence:store_json] -> [Config:recentFiles] ::mod(
  rule="definitional",
  confidence=1.0,
  description="Last 10 opened file paths"
)

[Persistence:store_json] -> [Config:hasPromptedDefault] ::mod(
  rule="definitional",
  confidence=1.0,
  description="Boolean — suppresses first-launch default app prompt"
)

[Persistence:Location] -> [AppData] ::mod(
  rule="definitional",
  confidence=1.0,
  description="%APPDATA%/com.markview.app/store.json"
)

