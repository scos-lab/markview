// ═══════════════════════════════════════════════
// 9. Performance Optimizations
// ═══════════════════════════════════════════════

[Optimization:PipelineSingleton] -> [Performance] ::mod(
  rule="causal",
  confidence=0.95,
  description="unified processor created once at module level, not per render"
)

[Optimization:StoreCaching] -> [Performance] ::mod(
  rule="causal",
  confidence=0.95,
  description="store.json loaded once via cached Promise, shared across all consumers"
)

[Optimization:StartupDelay] -> [Performance] ::mod(
  rule="causal",
  confidence=0.90,
  description="File association emit delay reduced from 500ms to 150ms"
)

[Optimization:SearchHighlight] -> [Performance] ::mod(
  rule="causal",
  confidence=0.95,
  description="Search highlight computed as HTML string in useMemo — avoids DOM manipulation that React wipes on re-render"
)

// ═══════════════════════════════════════════════
// 10. Known Issues & Future
// ═══════════════════════════════════════════════

[Issue:IconCache] -> [Windows] ::mod(
  rule="empirical",
  confidence=0.85,
  description="Windows caches app icons — transparent background icon may not display until cache cleared or next version"
)

[Issue:PackageSize] -> [Distribution] ::mod(
  rule="empirical",
  confidence=0.90,
  description="~9MB MSIX. markview.exe alone is 8.4MB (Tauri + WebView2 baseline). Cannot reduce further without switching away from Tauri"
)

[Future:PureRust] -> [MarkView] ::mod(
  rule="logical",
  confidence=0.60,
  description="Pure Rust implementation (iced/egui) could reduce binary to ~3MB but requires full rewrite"
)
