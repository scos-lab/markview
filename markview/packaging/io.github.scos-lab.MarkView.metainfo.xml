<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.scos-lab.MarkView</id>

  <name>MarkView</name>
  <summary>AI-native Markdown reader with charts and math</summary>

  <developer id="io.github.scos-lab">
    <name>scos-lab</name>
  </developer>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      MarkView renders Markdown the way modern LLMs produce it. Diagrams,
      equations, and data visualisations are first-class citizens, not
      afterthoughts.
    </p>
    <p>Supported natively:</p>
    <ul>
      <li>Mermaid — flowcharts, sequence, state, gantt, class, ERD, pie, mindmap, timeline, journey</li>
      <li>KaTeX — inline and block math, matrices, integrals, series</li>
      <li>Vega-Lite — bar, line, scatter, heatmap, candlestick, stacked area</li>
      <li>GitHub-flavored Markdown — tables, task lists, footnotes, strikethrough</li>
      <li>Syntax highlighting for 100+ languages via highlight.js</li>
    </ul>
    <p>
      Fast (cold start under 200 ms on SSD), lightweight (system WebKit, no
      Electron), and designed to be the default .md handler on your desktop.
    </p>
  </description>

  <launchable type="desktop-id">io.github.scos-lab.MarkView.desktop</launchable>

  <url type="homepage">https://github.com/scos-lab/markview</url>
  <url type="bugtracker">https://github.com/scos-lab/markview/issues</url>
  <url type="vcs-browser">https://github.com/scos-lab/markview</url>

  <categories>
    <category>Office</category>
    <category>Viewer</category>
    <category>TextEditor</category>
  </categories>

  <keywords>
    <keyword>markdown</keyword>
    <keyword>md</keyword>
    <keyword>mermaid</keyword>
    <keyword>katex</keyword>
    <keyword>reader</keyword>
    <keyword>viewer</keyword>
    <keyword>AI</keyword>
    <keyword>documentation</keyword>
  </keywords>

  <provides>
    <mediatype>text/markdown</mediatype>
    <mediatype>text/x-markdown</mediatype>
  </provides>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <content_rating type="oars-1.1" />

